<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:dialog="using:WalletWasabi.Fluent.ViewModels.Dialogs"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="420"
             x:DataType="dialog:DiscoverCoordinatorsDialogViewModel"
             x:CompileBindings="True"
             x:Class="WalletWasabi.Fluent.Views.Dialogs.DiscoverCoordinatorsDialogView">
  <ContentArea Title="{Binding Title}"
               Caption="These coordinators are self-advertised on Nostr. There is no guarantee that they are reachable."
               EnableNext="True" NextContent="Use Selected"
               EnableCancel="{Binding EnableCancel}"
               EnableBack="{Binding EnableBack}">
    <ContentArea.TopContent>
      <StackPanel Orientation="Horizontal" Spacing="5" HorizontalAlignment="Right">
        <Button Content="Refresh" Command="{Binding RefreshCommand}" Cursor="Hand" />
      </StackPanel>
    </ContentArea.TopContent>

    <Grid RowDefinitions="Auto,*">
      <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,10"
                  IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
        <ProgressRing Width="14" Height="14"
                      IsIndeterminate="True"
                      IsVisible="{Binding IsBusy}" />
        <TextBlock Text="{Binding StatusMessage}"
                   Foreground="{DynamicResource TextForegroundColor}"
                   Opacity="0.7"
                   VerticalAlignment="Center" />
      </StackPanel>

      <ListBox Grid.Row="1"
               ItemsSource="{Binding Coordinators}"
               SelectedItem="{Binding SelectedCoordinator}"
               SelectionMode="Single"
               Background="Transparent"
               BorderThickness="1"
               BorderBrush="{DynamicResource TextControlBorderBrush}"
               ScrollViewer.HorizontalScrollBarVisibility="Disabled">
        <ListBox.ItemTemplate>
          <DataTemplate DataType="dialog:DiscoveredCoordinatorItem">
            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" Margin="4"
                  Cursor="Hand"
                  ToolTip.Tip="{Binding Description}"
                  ToolTip.IsEnabled="{Binding HasDescription}">
              <TextBlock Grid.Row="0" Grid.Column="0"
                         Text="{Binding Name}"
                         FontWeight="Bold" />
              <TextBlock Grid.Row="0" Grid.Column="1"
                         Text="currently connected"
                         FontStyle="Italic"
                         Opacity="0.7"
                         Margin="10,0,0,0"
                         IsVisible="{Binding IsCurrentlyConnected}" />
              <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                         Text="{Binding UriString}"
                         Opacity="0.8" />
              <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                         Text="{Binding FirstSeenDescription}"
                         Opacity="0.6"
                         FontSize="11" />
            </Grid>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </Grid>
  </ContentArea>
</UserControl>
