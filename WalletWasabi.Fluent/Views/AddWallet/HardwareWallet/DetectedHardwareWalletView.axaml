<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:hardwareWallet="using:WalletWasabi.Fluent.ViewModels.AddWallet.HardwareWallet"
             mc:Ignorable="d" d:DesignWidth="428" d:DesignHeight="371"
             x:DataType="hardwareWallet:DetectedHardwareWalletViewModel"
             x:CompileBindings="True"
             x:Class="WalletWasabi.Fluent.Views.AddWallet.HardwareWallet.DetectedHardwareWalletView">
  <ContentArea Title="{Binding Title}"
               IsBusy="{Binding IsBusy}"
               EnableCancel="{Binding EnableCancel}"
               EnableBack="{Binding EnableBack}"
               EnableNext="False"
               ScrollViewer.VerticalScrollBarVisibility="Disabled">

    <QuestionControl YesCommand="{Binding NextCommand}"
                     NoCommand="{Binding NoCommand}"
                     HighlightButton="YesButton">
      <QuestionControl.IconContent>
        <Viewbox MaxHeight="180">
          <WalletIconControl WalletType="{Binding Type}" />
        </Viewbox>
      </QuestionControl.IconContent>
      <StackPanel Spacing="15" HorizontalAlignment="Center">
        <TextBlock Text="{Binding TypeName, StringFormat={}{0} was detected. Is this correct?}"
                   HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" />
        <CheckBox IsChecked="{Binding EnableCoinjoin}"
                  IsVisible="{Binding SupportsCoinjoin}"
                  HorizontalAlignment="Center"
                  Content="Enable coinjoin (adds a coinjoin account, confirm on device)"
                  ToolTip.Tip="Adds a SLIP-25 coinjoin account so this device can take part in coinjoins. You can also enable it later in the wallet settings." />
        <TextBlock Text="Trezor Suite or Trezor Bridge must be running to enable coinjoin."
                   IsVisible="{Binding IsBridgeUnavailable}"
                   HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"
                   Foreground="{DynamicResource SystemControlErrorTextForegroundBrush}" FontSize="12" />
      </StackPanel>
    </QuestionControl>
  </ContentArea>
</UserControl>
