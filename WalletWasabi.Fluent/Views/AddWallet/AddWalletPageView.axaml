<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:WalletWasabi.Fluent.ViewModels.AddWallet"
             xmlns:system="clr-namespace:System;assembly=System.Runtime"
             xmlns:r="clr-namespace:Avalonia.Xaml.Interactions.Responsive;assembly=Xaml.Behaviors.Interactions.Responsive"
             mc:Ignorable="d" d:DesignWidth="428" d:DesignHeight="371"
             x:DataType="vm:AddWalletPageViewModel"
             x:CompileBindings="True"
             x:Class="WalletWasabi.Fluent.Views.AddWallet.AddWalletPageView">
  <Interaction.Behaviors>
    <r:AdaptiveBehavior>
      <r:AdaptiveClassSetter MaxWidth="600" ClassName="mobile" />
    </r:AdaptiveBehavior>
  </Interaction.Behaviors>

  <ContentArea Title="{Binding Title}"
                 EnableCancel="{Binding EnableCancel}"
                 EnableBack="{Binding EnableBack}"
                 IsBusy="{Binding IsBusy}"
                 EnableNext="False">
    <Grid Name="PART_RootGrid" Classes="root-grid" MaxHeight="350">
      <Grid.Styles>
        <Style Selector="TileButton">
          <Setter Property="Cursor" Value="Hand" />
          <Setter Property="Width">
            <Setter.Value>
              <system:Double>NaN</system:Double>
            </Setter.Value>
          </Setter>
          <Setter Property="Height">
            <Setter.Value>
              <system:Double>NaN</system:Double>
            </Setter.Value>
          </Setter>
          <Setter Property="Margin" Value="10" />
          <Setter Property="Template">
            <ControlTemplate>
              <Border x:Name="PART_Border"
                      BorderThickness="{TemplateBinding BorderThickness}"
                      BorderBrush="{TemplateBinding BorderBrush}"
                      Background="{TemplateBinding Background}"
                      CornerRadius="10">
                <Grid RowDefinitions="5* 4*">
                  <Panel Grid.Row="0">
                    <PathIcon x:Name="PART_Icon"
                              Data="{TemplateBinding Icon}"
                              Width="{TemplateBinding IconSize}"
                              Height="{TemplateBinding IconSize}" />
                  </Panel>
                  <TextBlock Grid.Row="1" x:Name="PART_Text"
                             DockPanel.Dock="Bottom"
                             Text="{TemplateBinding Text}"
                             Foreground="{TemplateBinding Foreground}" />
                </Grid>
              </Border>
            </ControlTemplate>
          </Setter>
        </Style>
        <Style Selector="TileButton /template/ PathIcon#PART_Icon">
          <Setter Property="Margin" Value="0" />
        </Style>

        <!-- Grid default layout (Desktop) -->
        <Style Selector="Grid.root-grid">
          <Setter Property="Width" Value="530" />
          <Setter Property="ColumnDefinitions" Value="*,*,*" />
          <Setter Property="RowDefinitions" Value="*,Auto,*" />
        </Style>

        <!-- Grid mobile layout overrides -->
        <Style Selector="UserControl.mobile Grid.root-grid">
          <Setter Property="Width" Value="NaN" />
          <Setter Property="Height" Value="NaN" />
          <Setter Property="MaxHeight" Value="Infinity" />
          <Setter Property="ColumnDefinitions" Value="*" />
          <Setter Property="RowDefinitions" Value="Auto,Auto,Auto,Auto,Auto" />
        </Style>

        <!-- Button default positions (Desktop) -->
        <Style Selector="TileButton#CreateButton">
          <Setter Property="Grid.Row" Value="0" />
          <Setter Property="Grid.Column" Value="0" />
          <Setter Property="Grid.ColumnSpan" Value="3" />
        </Style>
        <Style Selector="TextBlock#OrText">
          <Setter Property="Grid.Row" Value="1" />
          <Setter Property="Grid.Column" Value="0" />
          <Setter Property="Grid.ColumnSpan" Value="3" />
        </Style>
        <Style Selector="TileButton#HardwareButton">
          <Setter Property="Grid.Row" Value="2" />
          <Setter Property="Grid.Column" Value="0" />
        </Style>
        <Style Selector="TileButton#ImportButton">
          <Setter Property="Grid.Row" Value="2" />
          <Setter Property="Grid.Column" Value="1" />
        </Style>
        <Style Selector="TileButton#RecoverButton">
          <Setter Property="Grid.Row" Value="2" />
          <Setter Property="Grid.Column" Value="2" />
        </Style>

        <!-- Button mobile layout overrides (Vertical Stack) -->
        <Style Selector="UserControl.mobile TileButton#CreateButton">
          <Setter Property="Grid.ColumnSpan" Value="1" />
        </Style>
        <Style Selector="UserControl.mobile TextBlock#OrText">
          <Setter Property="Grid.ColumnSpan" Value="1" />
          <Setter Property="Margin" Value="0 5" />
        </Style>
        <Style Selector="UserControl.mobile TileButton#HardwareButton">
          <Setter Property="Grid.Row" Value="2" />
          <Setter Property="Grid.Column" Value="0" />
        </Style>
        <Style Selector="UserControl.mobile TileButton#ImportButton">
          <Setter Property="Grid.Row" Value="3" />
          <Setter Property="Grid.Column" Value="0" />
        </Style>
        <Style Selector="UserControl.mobile TileButton#RecoverButton">
          <Setter Property="Grid.Row" Value="4" />
          <Setter Property="Grid.Column" Value="0" />
        </Style>

        <!-- TileButton mobile layout transformations (Horizontal row list style) -->
        <Style Selector="UserControl.mobile TileButton">
          <Setter Property="Height" Value="50" />
          <Setter Property="Margin" Value="0 5" />
        </Style>
        <Style Selector="UserControl.mobile TileButton /template/ Border#PART_Border Grid">
          <Setter Property="RowDefinitions" Value="*" />
          <Setter Property="ColumnDefinitions" Value="Auto, *" />
        </Style>
        <Style Selector="UserControl.mobile TileButton /template/ PathIcon#PART_Icon">
          <Setter Property="Grid.Row" Value="0" />
          <Setter Property="Grid.Column" Value="0" />
          <Setter Property="Margin" Value="15 0 10 0" />
          <Setter Property="HorizontalAlignment" Value="Left" />
          <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="UserControl.mobile TileButton /template/ TextBlock#PART_Text">
          <Setter Property="Grid.Row" Value="0" />
          <Setter Property="Grid.Column" Value="1" />
          <Setter Property="VerticalAlignment" Value="Center" />
          <Setter Property="HorizontalAlignment" Value="Left" />
          <Setter Property="Margin" Value="10 0 0 0" />
        </Style>
      </Grid.Styles>

      <TileButton Name="CreateButton" Text="Create a new wallet"
                     Classes="action bottomtext"
                     Icon="{StaticResource add_regular}"
                     IsDefault="True"
                     Command="{Binding CreateWalletCommand}" />

      <TextBlock Name="OrText" TextAlignment="Center" Text="or" />

      <TileButton Name="HardwareButton" Text="Connect to hardware wallet"
                     Icon="{StaticResource calculator_regular}"
                     Classes="bottomtext"
                     Command="{Binding ConnectHardwareWalletCommand}" />

      <TileButton Name="ImportButton" Text="Import a wallet"
                     Icon="{StaticResource import_regular}"
                     Classes="bottomtext"
                     Command="{Binding ImportWalletCommand}" />

      <TileButton Name="RecoverButton" Text="Recover a wallet"
                     Icon="{StaticResource recover_arrow_right_regular}"
                     Classes="bottomtext"
                     Command="{Binding RecoverWalletCommand}" />
    </Grid>
  </ContentArea>
</UserControl>
